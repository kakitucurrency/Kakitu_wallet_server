# KCB Buni API (get credentials from https://buni.kcbgroup.com)
KCB_CONSUMER_KEY=
KCB_CONSUMER_SECRET=
KCB_COMPANY_CODE=           # e.g. KE0010001 — provided by KCB
KCB_DEBIT_ACCOUNT=          # Kakitu's KCB account number (debited on cashout)
KCB_CALLBACK_URL=https://walletapi.kakitu.org   # No trailing slash — KCB appends /kcb/cashin/callback
KCB_ENV=sandbox             # "sandbox" | "production"

# Callback security (optional but recommended in production)
CALLBACK_SECRET=            # Shared secret KCB must include in callback requests

# Treasury wallet (Base/ERC20 — the address users transfer KSHS to for cash-out)
TREASURY_ADDRESS=

# Base / Ethereum (ERC20 KSHS on Base mainnet)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/REPLACE_WITH_YOUR_KEY
KSHS_CONTRACT_ADDRESS=0xe5E6b4b1054678DdCa4623E6Ce7214b1276A1946
MINTER_PRIVATE_KEY=         # Private key of the MINTER_ROLE wallet

# Database
DATABASE_URL=               # Railway injects this automatically
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=
DB_SSLMODE=disable

# Redis
REDIS_URL=                  # Railway injects this automatically

# Node
NODE_WS_URL=                # WebSocket URL of the Kakitu Nano node
RPC_URL=http://localhost:7076

# Firebase Cloud Messaging (optional)
FCM_API_KEY=

# Misc
ENVIRONMENT=development     # "development" | "production"
ADMIN_API_KEY=
WORK_URL=                   # PoW server URL (required unless BPOW_KEY is set)
BPOW_KEY=                   # BoomPoW key (alternative to WORK_URL)
